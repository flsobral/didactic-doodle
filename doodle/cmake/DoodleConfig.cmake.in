@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(Magic CONFIG)
set(_doodle_renderer "@DOODLE_RENDERER@")
if(_doodle_renderer STREQUAL "SKIA")
  if(NOT Doodle_SKIA_ROOT)
    set(Doodle_FOUND FALSE)
    set(Doodle_NOT_FOUND_MESSAGE "Doodle::Skia requires -DDoodle_SKIA_ROOT=<directory created by scripts/fetch-totalcross-skia.sh>.")
    return()
  endif()
  if(APPLE)
    set(_doodle_skia_library "${Doodle_SKIA_ROOT}/libskia-macos-arm64.a")
  elseif(UNIX)
    set(_doodle_skia_library "${Doodle_SKIA_ROOT}/libskia-linux-x86_64.a")
  elseif(WIN32)
    set(_doodle_skia_library "${Doodle_SKIA_ROOT}/libskia-windows-x64.lib")
  endif()
  if(NOT EXISTS "${Doodle_SKIA_ROOT}/headers/modules/skia/include/core/SkCanvas.h" OR NOT EXISTS "${_doodle_skia_library}")
    set(Doodle_FOUND FALSE)
    set(Doodle_NOT_FOUND_MESSAGE "Doodle_SKIA_ROOT does not contain matching Skia headers and archive.")
    return()
  endif()
  find_dependency(PNG)
  find_dependency(ZLIB)
  add_library(doodle_skia_external STATIC IMPORTED)
  set_target_properties(doodle_skia_external PROPERTIES IMPORTED_LOCATION "${_doodle_skia_library}" INTERFACE_INCLUDE_DIRECTORIES "${Doodle_SKIA_ROOT}/headers/modules/skia")
  target_link_libraries(doodle_skia_external INTERFACE PNG::PNG ZLIB::ZLIB)
  if(APPLE)
    find_library(_doodle_cocoa Cocoa REQUIRED)
    find_library(_doodle_corefoundation CoreFoundation REQUIRED)
    find_library(_doodle_coregraphics CoreGraphics REQUIRED)
    find_library(_doodle_coretext CoreText REQUIRED)
    find_library(_doodle_imageio ImageIO REQUIRED)
    find_library(_doodle_metal Metal REQUIRED)
    find_library(_doodle_quartzcore QuartzCore REQUIRED)
    target_link_libraries(doodle_skia_external INTERFACE ${_doodle_cocoa} ${_doodle_corefoundation} ${_doodle_coregraphics} ${_doodle_coretext} ${_doodle_imageio} ${_doodle_metal} ${_doodle_quartzcore})
  endif()
endif()
include("${CMAKE_CURRENT_LIST_DIR}/DoodleTargets.cmake")
