@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
set(_board_backend "@BOARD_BACKEND@")
if(_board_backend STREQUAL "SDL3")
  find_dependency(SDL3 CONFIG)
  if("@BOARD_SDL3_ENABLE_VULKAN@" STREQUAL "ON")
    find_dependency(Vulkan)
  endif()
endif()
include("${CMAKE_CURRENT_LIST_DIR}/BoardTargets.cmake")
